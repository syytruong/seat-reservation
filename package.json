{
  "name": "seat-reservation",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build -w @seat/shared && npm run build -ws --if-present",
    "build:shared": "npm run build -w @seat/shared",
    "dev:auth": "npm run dev -w @seat/auth-service",
    "dev:seat": "npm run dev -w @seat/seat-service",
    "dev:payment": "npm run dev -w @seat/payment-service",
    "dev:web": "npm run dev -w @seat/web",
    "migrate": "node scripts/migrate.mjs all",
    "migrate:auth": "node scripts/migrate.mjs auth",
    "migrate:seat": "node scripts/migrate.mjs seat",
    "migrate:payment": "node scripts/migrate.mjs payment",
    "test": "echo \"No tests configured yet\""
  },
  "dependencies": {
    "amqplib": "^0.10.8",
    "argon2": "^0.43.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.6.1",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.16.3",
    "pino": "^9.7.0",
    "prom-client": "^15.1.3",
    "zod": "^4.0.5"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.7",
    "@types/cookie-parser": "^1.4.9",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.0.14",
    "@types/pg": "^8.15.4",
    "typescript": "^5.8.3",
    "tsx": "^4.20.3"
  }
}
