# Required secrets. Do not add application defaults for these in code.
JWT_ACCESS_SECRET=replace-with-32-plus-random-bytes
WEBHOOK_SECRET=replace-with-32-plus-random-bytes

# Browser/API routing
CORS_ORIGIN=http://localhost:8080
NODE_ENV=development
LOG_LEVEL=info

# Shared infrastructure
POSTGRES_USER=seat
POSTGRES_PASSWORD=seat
POSTGRES_DB=postgres
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672
REDIS_URL=redis://redis:6379

# Service databases
AUTH_DATABASE_URL=postgres://seat:seat@postgres:5432/auth_db
SEAT_DATABASE_URL=postgres://seat:seat@postgres:5432/seat_db
PAYMENT_DATABASE_URL=postgres://seat:seat@postgres:5432/payment_db

# Service ports
AUTH_PORT=3001
SEAT_PORT=3002
PAYMENT_PORT=3003
WEB_PORT=5173

# Auth/session policy
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_DAYS=90
REFRESH_REUSE_GRACE_SECONDS=15

# Seat/payment policy
HOLD_TTL_SECONDS=600
SEAT_PRICE_CENTS=2500
WEBHOOK_TOLERANCE_SECONDS=300

# Rate limits
RATE_LIMIT_LOGIN_MAX=10
RATE_LIMIT_API_MAX=120
RATE_LIMIT_SEAT_MAX=60
RATE_LIMIT_PAYMENT_MAX=30
